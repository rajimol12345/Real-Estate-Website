{
  "name": "real-estate-root",
  "version": "1.0.0",
  "description": "Root package.json for monorepo deployment",
  "scripts": {
    "start": "node server/server.js",
    "build": "npm install --prefix server && npm install --prefix client-app --legacy-peer-deps",
    "install-server": "npm install --prefix server",
    "install-client": "npm install --prefix client-app --legacy-peer-deps"
  },
  "engines": {
    "node": ">=22.22.0"
  }
}
